rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: subjects
    // Document ID: {subjectId}
    //
    // Collection: attendance_sessions
    // Document ID: {sessionId}
    //
    // Collection: attendance_records
    // Document ID: {studentUid}_{sessionId}
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isEmailOwner(email) {
      return isAuthenticated() && request.auth.token.email == email;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['subjectId', 'teacherEmail', 'shortCode', 'isActive', 'location', 'radius', 'createdAt']) &&
             data.subjectId is string &&
             data.teacherEmail is string &&
             data.shortCode is string &&
             data.isActive is bool &&
             data.location is map &&
             data.radius is number &&
             data.createdAt is timestamp;
    }

    function isValidRecord(data) {
      return data.keys().hasAll(['sessionId', 'subjectId', 'studentUid', 'studentName', 'timestamp', 'status', 'location']) &&
             data.sessionId is string &&
             data.subjectId is string &&
             data.studentUid is string &&
             data.studentUid == request.auth.uid &&
             data.studentName is string &&
             data.timestamp is timestamp &&
             data.status == 'present' &&
             data.location is map;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    match /subjects/{subjectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.teacherEmail == request.auth.token.email;
    }

    match /attendance_sessions/{sessionId} {
      // Allow reading sessions to verify code and location
      // We allow list and get for everyone so students can find the session by shortCode
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.teacherEmail == request.auth.token.email;
    }

    match /attendance_records/{recordId} {
      // Students can read their own records, teachers can read all (for now)
      allow read: if isAuthenticated();
      
      // Validate record creation
      allow create: if isAuthenticated() && 
                      isValidRecord(request.resource.data) && 
                      recordId == request.auth.uid + "_" + request.resource.data.sessionId;
                      
      // Allow updates if needed (e.g. fixing status)
      allow update: if isAuthenticated() && 
                      isValidRecord(request.resource.data) && 
                      isOwner(resource.data.studentUid);
                      
      allow delete: if isAuthenticated() && isOwner(resource.data.studentUid);
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
